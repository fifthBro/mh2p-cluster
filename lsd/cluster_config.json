{
  "buildVersion": "__VERSION__",
  "config": {
    "enableFileLogging": true,
    "enableFileHashing": true,
    "enableExternalLogging": true,
    "enableRoundaboutLatching": true,
    "enableHeartbeat": true,
    "maneuverStateMask": 0,
    "heartbeatInterval": 2000,
    "forceImperial": false,
    "forceRHD": false,
    "logFilePath": "/tmp/cluster.log",
    "hashedLogFilePath": "/tmp/cluster_hashed.log",
    "logFileSize": 50,
    "bargraphMode": "auto",
    "dynamicBargraphDistance": 100,
    "dynamicBargraphPercent": 50,
    "metricUnitThreshold": 1000,
    "imperialUnitThreshold": 161,
    "imperialSmallUnit": "auto",
    "destinationDisplayDuration": 5000,
    "enableMapRender": true,
    "aaClusterMode": "h264",
    "mirror":   { "mode": "fill",   "zoomX": 1.0, "zoomY": 1.0, "panX": 0.0, "panY": 0.0 },
    "gal_h264": { "codecRes": 720,  "mode": "letter", "zoomX": 1.0, "zoomY": 1.0, "panX": 0.0, "panY": 0.0 }
  },
  "carConfig": {
    "5_3": {
      "name": "Cayenne E3",  "bargraphMode": "always",   "aaClusterMode": "h264",
      "mirror":   { "mode": "fill",   "zoomX": 0.60, "zoomY": 0.70, "panX": 0.02, "panY": 0.02 },
      "gal_h264": { "codecRes": 720,  "mode": "letter", "zoomX": 1.0, "zoomY": 1.0, "panX": 0.0, "panY": 0.0 }
    },
    "6_8": {
      "name": "911 992",     "bargraphMode": "always",   "aaClusterMode": "h264",
      "mirror":   { "mode": "fill",   "zoomX": 0.60, "zoomY": 0.70, "panX": 0.02, "panY": 0.02 },
      "gal_h264": { "codecRes": 720,  "mode": "letter", "zoomX": 1.0, "zoomY": 1.0, "panX": 0.0, "panY": 0.0 }
    },
    "6_2": {
      "name": "Panamera G2", "bargraphMode": "always",   "aaClusterMode": "h264",
      "mirror":   { "mode": "fill",   "zoomX": 0.60, "zoomY": 0.70, "panX": 0.02, "panY": 0.02 },
      "gal_h264": { "codecRes": 480,  "mode": "letter", "zoomX": 1.0, "zoomY": 1.0, "panX": 0.0, "panY": 0.0 }
    },
    "4_1": {
      "name": "Macan",       "bargraphMode": "distance", "aaClusterMode": "h264",
      "mirror":   { "mode": "fill",   "zoomX": 0.60, "zoomY": 0.70, "panX": 0.02, "panY": 0.02 },
      "gal_h264": { "codecRes": 480,  "mode": "letter", "zoomX": 1.0, "zoomY": 1.0, "panX": 0.0, "panY": 0.0 }
    }
  },
  "dynamicThresholds": {
    "veryFar":    { "boundary": 5000, "distance": 100, "rateLimit": 2000 },
    "far":        { "boundary": 1000, "distance": 50,  "rateLimit": 500  },
    "approaching":{ "boundary": 500,  "distance": 25,  "rateLimit": 250  },
    "near":       { "boundary": 200,  "distance": 15,  "rateLimit": 200  },
    "close":      { "boundary": 100,  "distance": 15,  "rateLimit": 150  },
    "veryClose":  { "boundary": 50,   "distance": 10,  "rateLimit": 120  },
    "now":        {                    "distance": 5,   "rateLimit": 100  }
  },
